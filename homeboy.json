{
  "id": "data-machine-frontend-chat",
  "changelog_target": "docs/CHANGELOG.md",
  "remote_path": "wp-content/plugins/data-machine-frontend-chat",
  "extensions": {
    "wordpress": {}
  },
  "version_targets": [
    {
      "file": "data-machine-frontend-chat.php",
      "pattern": "Version:\\s*([\\d.]+)"
    },
    {
      "file": "data-machine-frontend-chat.php",
      "pattern": "DATA_MACHINE_FRONTEND_CHAT_VERSION',\\s*'([\\d.]+)"
    }
  ]
}
